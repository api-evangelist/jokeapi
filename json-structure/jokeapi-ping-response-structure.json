{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/jokeapi/refs/heads/main/json-structure/jokeapi-ping-response-structure.json",
  "name": "PingResponse",
  "description": "Ping envelope.",
  "type": "object",
  "properties": {
    "error": {
      "type": "boolean",
      "example": false
    },
    "ping": {
      "type": "string",
      "example": "Pong!"
    },
    "timestamp": {
      "type": "int32",
      "example": 1780051223357
    }
  },
  "required": [
    "error",
    "ping",
    "timestamp"
  ]
}