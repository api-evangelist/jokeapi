{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/jokeapi/refs/heads/main/json-schema/jokeapi-ping-response-schema.json",
  "title": "PingResponse",
  "description": "Ping envelope.",
  "type": "object",
  "properties": {
    "error": {
      "type": "boolean",
      "example": false
    },
    "ping": {
      "type": "string",
      "example": "Pong!"
    },
    "timestamp": {
      "type": "integer",
      "example": 1780051223357
    }
  },
  "required": [
    "error",
    "ping",
    "timestamp"
  ]
}